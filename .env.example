GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
TEAM_NAME=YourTeamName
CONTACT_EMAIL=team@example.com
BOT_VERSION=1.0.0

# Conversation tuning (optional — defaults shown)
AUTO_REPLY_THRESHOLD=3
MAX_CONVERSATION_TURNS=10
AUTO_REPLY_SIMILARITY_THRESHOLD=0.85

# LLM generation (optional — defaults shown)
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3
